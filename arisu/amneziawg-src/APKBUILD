# Contributor:
# Maintainer:
pkgname=amneziawg-src
pkgver=1.0.20260611
_modname=amneziawg
pkgrel=0
pkgdesc="A contemporary version of the popular VPN protocol, WireGuard"
url="https://amnezia.org"
arch="all"
license="GPL-2.0"
depends="akms"
makedepends="rsync"
install="$pkgname.post-deinstall"
source="amneziawg-linux-kernel-module-$pkgver.tar.gz::https://github.com/amnezia-vpn/amneziawg-linux-kernel-module/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir"/amneziawg-linux-kernel-module-$pkgver
options="!check" # No tests available

package() {
	mkdir -p "$pkgdir"/usr/src/$_modname-$pkgver
	rsync --recursive --exclude=*.cmd --exclude=*.rules --exclude=*.d --exclude=*.ko --exclude=*.mod --exclude=*.mod.c --exclude=*.o --exclude=modules.order src/ "$pkgdir"/usr/src/$_modname-$pkgver

	cat > "$pkgdir"/usr/src/$_modname-$pkgver/AKMBUILD <<-EOF
		modname=$_modname
		modver=$pkgver-r$pkgrel
		built_modules="$_modname.ko"
	EOF
}

sha512sums="
3a99b7812b86087aa6f2c0af02a1c43aa6f540d025a1613d484930a99d3589c4ba2e6c2fb7f1b941357bf13855a56a220ff7c0688b22359f954b4dc689db0fdc  amneziawg-linux-kernel-module-1.0.20260611.tar.gz
"
