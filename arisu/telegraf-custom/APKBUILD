# Contributor:
# Maintainer:
# Source: https://git.alpinelinux.org/aports/tree/community/telegraf/APKBUILD?h=3.24-stable
_origpkgname=telegraf
_origpkgrel=5
pkgname=$_origpkgname-custom
pkgver=1.37.0
pkgrel=0
_commit=f80cc596f # git rev-parse --short HEAD
_branch=release-${pkgver%.*}
pkgdesc="A plugin-driven server agent for collecting & reporting metrics, part of the InfluxDB project"
url="https://www.influxdata.com/time-series-platform/telegraf/"
arch="x86_64 aarch64"
license="MIT"
makedepends="go linux-headers"
checkdepends="tzdata bash"
install="$pkgname.pre-install"
subpackages="$pkgname-openrc $pkgname-doc"
options="net"
source="telegraf-$pkgver.tar.gz::https://github.com/influxdata/telegraf/archive/v$pkgver.tar.gz
	fix-test-failures-with-2025-timestamps.patch
	go-1.26.patch
	go-1.26-powerdns-procstat.patch
	telegraf.initd
	telegraf.confd
	"
builddir="$srcdir"/telegraf-$pkgver
provides=$_origpkgname

_custom_plugins="inputs.cpu
	inputs.disk
	inputs.diskio
	inputs.docker
	inputs.exec
	inputs.execd
	inputs.http_response
	inputs.kernel
	inputs.mem
	inputs.net
	inputs.netstat
	inputs.processes
	inputs.prometheus
	inputs.prometheus.tags
	inputs.sensors
	inputs.smart
	inputs.swap
	inputs.system
	inputs.x509_cert
	inputs.zfs
	outputs.prometheus_client
	parsers.influx
	"

build() {
	local pkg="github.com/influxdata/telegraf/internal"
	local ldflags="-X $pkg.Version=$pkgver -X $pkg.Branch=$_branch -X $pkg.Commit=$_commit"
	local plugins="$(printf '%s\n' $_custom_plugins | tr '\n' ',')"
	go build -ldflags "$ldflags" -tags "custom,$plugins" ./cmd/telegraf

	# Generate sample config.
	./telegraf config >telegraf.conf
}

check() {
	local pkgs="$(go list ./...)"
	# Temporarily skip socket tests (see 211b775ca493)
	if [ "$CARCH" = "x86_64" ]; then
		local skip="
			plugins/common/socket
			plugins/inputs/syslog
		"
		pkgs="$(go list ./... | grep -Ev "$(echo $skip | tr ' ' '|')")"
	fi
	if [ "$CARCH" = "aarch64" ]; then
		local skip="
			plugins/common/socket
			plugins/inputs/influxdb_v2_listener
			plugins/inputs/syslog
			plugins/inputs/tail
			plugins/outputs/sql
			plugins/processors/execd
			plugins/processors/reverse_dns
			plugins/processors/scale
		"
		pkgs="$(go list ./... | grep -Ev "$(echo $skip | tr ' ' '|')")"
	fi

	# shellcheck disable=2046
	go test -short $pkgs
}

package() {
	install -Dm755 "$srcdir/$_origpkgname.initd" "$pkgdir/etc/init.d/$_origpkgname"
	install -Dm644 "$srcdir/$_origpkgname.confd" "$pkgdir/etc/conf.d/$_origpkgname"
	install -Dm755 "$builddir/$_origpkgname" "$pkgdir/usr/bin/$_origpkgname"
	install -Dm644 "$builddir/$_origpkgname.conf" "$pkgdir/etc/$_origpkgname.conf"
	install -dm755 "$pkgdir/etc/$_origpkgname.conf.d"
	install -Dm644 "$builddir/LICENSE" "$pkgdir/usr/share/licenses/$_origpkgname/LICENSE"
}

