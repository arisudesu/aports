# Contributor:
# Maintainer:
pkgname=xray
pkgver=26.3.27
pkgrel=1
pkgdesc="Platform for building proxies to bypass network restrictions"
url="https://github.com/XTLS/Xray-core"
arch="x86_64"
license="MPL-2.0"
install="$pkgname.pre-install $pkgname.pre-upgrade"
subpackages="
	$pkgname-doc
	$pkgname-openrc
	"
pkggroups=xray
source="https://github.com/XTLS/Xray-core/releases/download/v$pkgver/Xray-linux-64.zip
	xray.json.example
	xray.initd
	"
options="!check !fhs" # installs to /opt

package() {
	install -D -m755 "$srcdir"/xray "$pkgdir"/opt/$pkgname/xray

	install -d -m750 -o root -g xray "$pkgdir"/etc/xray
	install -D -m640 -o root -g xray "$srcdir"/xray.json.example "$pkgdir"/etc/xray/xray.json.example

	install -D -m644 "$srcdir"/README.md "$pkgdir"/usr/share/doc/$pkgname/README.md

	for f in geoip.dat geosite.dat; do
		install -D -m644 "$srcdir"/$f "$pkgdir"/usr/share/$pkgname/$f
	done

	install -d -m755 "$pkgdir"/opt/bin
	ln -s ../$pkgname/xray "$pkgdir"/opt/bin/

	install -D -m755 "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
}

sha512sums="
