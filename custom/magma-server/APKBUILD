# Contributor:
# Maintainer:
pkgname=magma-server
pkgver=1.12.2_git20220621
pkgrel=0
pkgdesc="Minecraft Magma server"
url="https://magmafoundation.org/"
arch="noarch"
license="custom"
depends="openjdk8-jre-base dtach"
makedepends="openjdk8-jre-base"
install="$pkgname.pre-install"
options="!check net"
pkgusers="magma"
pkggroups="magma"
subpackages="$pkgname-openrc"
_mcver="${pkgver%_git*}"
_magmaver=866f4a2c
_filever="${_mcver}-${_magmaver}"
source="https://git.magmafoundation.org/api/v4/projects/7/packages/maven/org/magmafoundation/Magma/${_filever}/Magma-${_filever}.jar
		$pkgname.bin
		$pkgname.initd
		$pkgname.confd"

package() {
	install -m 644 -D "$srcdir/"Magma-${_filever}.jar \
		"$pkgdir"/usr/share/magma-server/magma-server.jar

	install -m 755 -D "$srcdir"/$pkgname.bin   "$pkgdir"/usr/bin/$pkgname
	install -m 755 -D "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -m 644 -D "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

