# Contributor:
# Maintainer:
pkgname=telegram-bot-api
pkgver=6.0.2
pkgrel=1
pkgdesc="Telegram Bot API server"
url="https://github.com/tdlib/telegram-bot-api"
arch="all !s390x" # tdlib fails to build on big-endian
license="BSL-1.0"
options="!check" # No test suite from upstream
pkgusers="$pkgname"
pkggroups="$pkgname"
makedepends="cmake openssl-dev zlib-dev gperf linux-headers"
install="$pkgname.pre-install"
subpackages="$pkgname-doc $pkgname-openrc"
_commit=8a0f1dd730aa41ab7b792b9ff03d92b1c5022c9f
_tdlib_commit=ab3a8282d4ee307d341071267ef1090b1a941478
source="$pkgname-$_commit.tar.gz::https://github.com/tdlib/telegram-bot-api/archive/$_commit.tar.gz
		td-$_tdlib_commit.tar.gz::https://github.com/tdlib/td/archive/$_tdlib_commit.tar.gz
		$pkgname.initd
		$pkgname.confd"
builddir="$srcdir/$pkgname-$_commit"

prepare() {
	mv -T "$srcdir/td-$_tdlib_commit" "$srcdir/$pkgname-$_commit/td"
}

build() {
	cmake -B build \
		-DCMAKE_BUILD_TYPE=MinSizeRel \
		-DCMAKE_INSTALL_PREFIX:PATH=/usr

	cmake --build build
}

package() {
	DESTDIR="$pkgdir" cmake --install build

	install -m644 -D -t "$pkgdir/usr/share/licenses/$pkgname" \
		LICENSE_1_0.txt
	install -m644 -D -t "$pkgdir/usr/share/doc/$pkgname" \
		README.md

	install -m 755 -D "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -m 644 -D "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
}

